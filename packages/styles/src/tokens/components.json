{
  "kds": {
    "color": {
      "spinner": {
        "progress": {
          "onFilled": {
            "$extensions": {
              "studio.tokens": {
                "modify": {
                  "type": "lighten",
                  "value": "0",
                  "space": "lch"
                }
              }
            },
            "$type": "color",
            "$value": "{kds.color.text-and-icon.primary-inverted}"
          },
          "onTransparent": {
            "$type": "color",
            "$value": "{kds.color.text-and-icon.neutral}"
          }
        },
        "track": {
          "onFilled": {
            "$extensions": {
              "studio.tokens": {
                "modify": {
                  "type": "alpha",
                  "value": "0.24",
                  "space": "lch"
                }
              }
            },
            "$type": "color",
            "$value": "{kds.color.text-and-icon.primary-inverted}"
          },
          "onTransparent": {
            "$extensions": {
              "studio.tokens": {
                "modify": {
                  "type": "alpha",
                  "value": "0.24",
                  "space": "lch"
                }
              }
            },
            "$type": "color",
            "$value": "{kds.color.text-and-icon.neutral}"
          }
        }
      },
      "desktop-header": {
        "background": {
          "default": {
            "$type": "color",
            "$value": "{kds.color.background.page.default}"
          },
          "muted": {
            "$type": "color",
            "$value": "{kds.color.surface.default}"
          }
        },
        "text-and-icon": {
          "neutral": {
            "$type": "color",
            "$value": "{kds.color.text-and-icon.neutral}"
          },
          "muted": {
            "$type": "color",
            "$value": "{kds.color.text-and-icon.muted}"
          }
        }
      }
    }
  },
  "kds-elevation-level-0": {
    "$type": "boxShadow",
    "$value": {
      "x": "0",
      "y": "0",
      "blur": "0",
      "spread": "0",
      "color": "#000000",
      "type": "dropShadow"
    }
  },
  "kds-elevation-level-1": {
    "$type": "boxShadow",
    "$value": {
      "x": "0",
      "y": "0",
      "blur": "0",
      "spread": "0",
      "color": "#000000",
      "type": "dropShadow"
    }
  },
  "kds-elevation-level-2": {
    "$type": "boxShadow",
    "$value": {
      "x": "0",
      "y": "0",
      "blur": "0",
      "spread": "0",
      "color": "#000000",
      "type": "dropShadow"
    }
  }
}